{
    "headers": [
        {
            "source": "/api/(.*)",
            "headers": [
                { "key": "Access-Control-Allow-Origin", "value": "https://proyecto-colegio.vercel.app" },
                { "key": "Access-Control-Allow-Methods", "value": "GET, POST, PUT, DELETE, OPTIONS" },
                { "key": "Access-Control-Allow-Headers", "value": "Content-Type, Authorization" },
                { "key": "Access-Control-Max-Age", "value": "86400" },
                { "key": "X-Content-Type-Options", "value": "nosniff" },
                { "key": "X-Frame-Options", "value": "DENY" },
                { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
                { "key": "X-XSS-Protection", "value": "1; mode=block" },
                { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
            ]
        }
    ],
    "functions": {
        "api/galeria.js": { "memory": 512, "maxDuration": 30 },
        "api/noticias.js": { "memory": 256, "maxDuration": 15 },
        "api/documentos.js": { "memory": 256, "maxDuration": 15 },
        "api/notas.js": { "memory": 256, "maxDuration": 15 }
    }
}
