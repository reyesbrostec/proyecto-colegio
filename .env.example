# ─── Colegio UEPAM — Variables de Entorno ───
# Copia este archivo como .env y completa los valores reales.
# NUNCA subas el archivo .env a GitHub.

# Base de datos PostgreSQL (Render provee DATABASE_URL automáticamente)
DATABASE_URL=postgresql://usuario:contraseña@host:5432/nombre_db

# Clave secreta para firmar tokens JWT (cambiar en producción)
JWT_SECRET=cambia_esto_por_una_clave_segura_larga_y_aleatoria

# Puerto (opcional, por defecto 3000)
PORT=3000

# Cloudinary (para subida de fotos en la galería)
# Regístrate gratis en https://cloudinary.com y obtén tus credenciales
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret
